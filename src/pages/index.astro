---
import Layout from "@layouts/Layout.astro";
import Profile from "@components/Profile.astro";
import CapabilitiesBadges from "@components/CapabilitiesBadges.astro";
import ProjectCard from "@components/ProjectCard.astro";
import { getCollection } from "astro:content";

// Get all projects
const allProjects = await getCollection("projects");

// Sort projects by id (ascending order)
const sortedProjects = allProjects.sort((a, b) => a.data.id - b.data.id);
---

<Layout
  title="Brandon Palmeros | Consultor Digital en Veracruz"
  description="Consultor digital en Veracruz. Combino marketing, diseño, desarrollo, automatización e inteligencia artificial para que tu negocio opere mejor y escale con tecnología."
>
  <div class="flex flex-col gap-16">
    <section class="flex flex-col gap-8">
      <Profile />

      <CapabilitiesBadges />
    </section>

    <section class="flex flex-col gap-6">
      <h2 class="text-xl font-medium tracking-tight text-neutral-100">Proyectos Destacados</h2>
      <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
        {sortedProjects.map((project) => <ProjectCard project={project} />)}
      </div>
    </section>
  </div>
</Layout>
