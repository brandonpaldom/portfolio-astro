---
import Layout from "@layouts/Layout.astro";

import ResumeItem from "@components/ResumeItem.astro";

import resume from "@data/resume.json";
---

<Layout
  title="Currículum | Brandon Palmeros - Desarrollo Web"
  subtitle="Currículum"
  description="Conoce mi experiencia en desarrollo web, diseño UI/UX y marketing digital. Formación, certificaciones y proyectos destacados."
>
  <section class="mt-4 flex flex-col gap-4">
    <h2 class="heading2">Educación</h2>
    {resume.education.map((item) => <ResumeItem item={item} />)}
  </section>
  <section class="mt-4 flex flex-col gap-4">
    <h2 class="heading2">Experiencia</h2>
    {resume.experience.map((item) => <ResumeItem item={item} />)}
  </section>
  <section class="mt-4 flex flex-col gap-4">
    <h2 class="heading2">Certificaciones</h2>
    {resume.certifications.map((item) => <ResumeItem item={item} />)}
  </section>
</Layout>
