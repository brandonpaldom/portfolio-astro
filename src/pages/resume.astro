---
import Layout from "@layouts/Layout.astro";

import ResumeItem from "@components/ResumeItem.astro";

import resume from "@data/resume.json";
---

<Layout
  title="Currículum · Brandon Palmeros — Consultor digital"
  subtitle="Currículum"
  description="Marketing, diseño, desarrollo y automatización: las piezas que llevo años combinando para que los negocios crezcan con tecnología. Esta es la trayectoria detrás."
>
  <div class="flex flex-col gap-12 mt-6">
    <section class="flex flex-col gap-6">
      <h2 class="text-xl font-medium tracking-tight text-neutral-100">Experiencia</h2>
      <div class="flex flex-col gap-4">
        {resume.experience.map((item) => <ResumeItem item={item} />)}
      </div>
    </section>

    <section class="flex flex-col gap-6">
      <h2 class="text-xl font-medium tracking-tight text-neutral-100">Educación</h2>
      <div class="flex flex-col gap-4">
        {resume.education.map((item) => <ResumeItem item={item} />)}
      </div>
    </section>
    
    <section class="flex flex-col gap-6">
      <h2 class="text-xl font-medium tracking-tight text-neutral-100">Certificaciones</h2>
      <div class="flex flex-col gap-4">
        {resume.certifications.map((item) => <ResumeItem item={item} />)}
      </div>
    </section>
  </div>
</Layout>
