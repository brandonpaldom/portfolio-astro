---
import Layout from "@layouts/Layout.astro";

import { Rocket } from "@lucide/astro";
---

<Layout title="Página no encontrada | Brandon Palmeros" description="La página que buscas no existe o ha sido movida.">
  <div class="flex flex-col items-center py-16 text-center">
    <div class="flex h-20 w-20 items-center justify-center rounded-full bg-white/5 ring-1 ring-white/10 mb-8 animate-pulse text-neutral-400">
      <Rocket width={32} height={32} />
    </div>
    <h1 class="text-3xl font-display font-semibold tracking-tight text-neutral-100">¡Ups! Parece que te has perdido.</h1>
    <p class="text-neutral-400 mt-4 mb-8">La página que buscas no existe o ha sido movida.</p>
    <a href="/" class="flex items-center gap-2 rounded-lg bg-white/5 px-6 py-3 text-sm font-medium text-neutral-300 ring-1 ring-white/10 hover:bg-white/10 hover:text-white transition-all duration-300">
      Volver al inicio
    </a>
  </div>
</Layout>
