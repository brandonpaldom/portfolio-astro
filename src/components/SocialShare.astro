---
import { Twitter, Linkedin, Facebook, Link as LinkIcon } from "@lucide/astro";

interface Props {
  title: string;
  description: string;
  url: string;
}

const { title, description, url } = Astro.props;

const encodedTitle = encodeURIComponent(title);
const encodedDescription = encodeURIComponent(description);
const encodedUrl = encodeURIComponent(url);

const twitterUrl = `https://x.com/intent/post?text=${encodedTitle}&url=${encodedUrl}`;
const linkedinUrl = `https://www.linkedin.com/sharing/share-offsite/?url=${encodedUrl}`;
const facebookUrl = `https://www.facebook.com/sharer/sharer.php?u=${encodedUrl}`;
---

<div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
  <h3 class="text-sm font-medium text-neutral-300">Compartir artículo</h3>

  <div class="flex flex-wrap items-center gap-3">
    <a href={twitterUrl} target="_blank" rel="noopener noreferrer" class="flex h-10 w-10 items-center justify-center rounded-full bg-white/5 text-neutral-400 ring-1 ring-white/10 hover:bg-white/10 hover:text-white transition-all duration-300" aria-label="Compartir en X">
      <Twitter width={18} height={18} />
    </a>

    <a href={linkedinUrl} target="_blank" rel="noopener noreferrer" class="flex h-10 w-10 items-center justify-center rounded-full bg-white/5 text-neutral-400 ring-1 ring-white/10 hover:bg-white/10 hover:text-white transition-all duration-300" aria-label="Compartir en LinkedIn">
      <Linkedin width={18} height={18} />
    </a>

    <a href={facebookUrl} target="_blank" rel="noopener noreferrer" class="flex h-10 w-10 items-center justify-center rounded-full bg-white/5 text-neutral-400 ring-1 ring-white/10 hover:bg-white/10 hover:text-white transition-all duration-300" aria-label="Compartir en Facebook">
      <Facebook width={18} height={18} />
    </a>

    <button id="copy-link-btn" class="flex h-10 items-center gap-2 rounded-full bg-white/5 px-4 text-sm font-medium text-neutral-400 ring-1 ring-white/10 hover:bg-white/10 hover:text-white transition-all duration-300" data-url={url}>
      <LinkIcon width={16} height={16} />
      <span>Copiar enlace</span>
    </button>
  </div>
</div>

<script>
  document.addEventListener("astro:page-load", function () {
    const copyBtn = document.getElementById("copy-link-btn");

    if (copyBtn) {
      copyBtn.addEventListener("click", async function () {
        const url = this.getAttribute("data-url");
        const span = this.querySelector("span");
        const originalText = span?.textContent ?? "";

        try {
          await navigator.clipboard.writeText(url || "");
          if (span) {
            span.textContent = "¡Copiado!";
            setTimeout(() => {
              span.textContent = originalText;
            }, 2000);
          }
        } catch (err) {
          console.error("Error copying to clipboard:", err);
          if (span) {
            span.textContent = "Error";
            setTimeout(() => {
              span.textContent = originalText;
            }, 2000);
          }
        }
      });
    }
  });
</script>
