---
import Chip from "./Chip.astro";

import { MapPin, Mail, Github, Linkedin } from "@lucide/astro";

import profile from "@data/profile.json";
import contact from "@data/contact.json";
---

<header class="flex flex-col gap-6 w-full">
  <div class="flex items-center gap-4">
    <div class="relative flex h-16 w-16 items-center justify-center rounded-full bg-white/5 ring-1 ring-white/10 overflow-hidden">
      <img src={profile.imageUrl} alt="Foto de perfil" class="h-14 w-14 rounded-full object-cover" />
    </div>
    <div class="flex flex-col">
      <h1 class="text-2xl font-semibold tracking-tight text-neutral-100">{profile.name}</h1>
      <p class="text-neutral-400">{profile.title}</p>
    </div>
  </div>

  <div class="flex flex-wrap items-center gap-3">
    <Chip icon label={profile.location} color="chip-secondary">
      <MapPin width={14} height={14} />
    </Chip>
    <Chip icon label="Disponible para proyectos" color="chip-secondary">
      <span class="inline-flex h-1.5 w-1.5 animate-pulse rounded-full bg-emerald-400"></span>
    </Chip>
  </div>

  <div class="flex items-center gap-3">
    {
      contact.map((item) => (
        <a 
          href={item.url} 
          class="flex h-9 w-9 items-center justify-center rounded-lg bg-white/5 text-neutral-400 ring-1 ring-white/10 hover:bg-white/10 hover:text-neutral-200 transition-all duration-300"
          target="_blank" 
          rel="noopener noreferrer"
        >
          {item.icon === "EmailIcon" && <Mail width={18} height={18} />}
          {item.icon === "GitHubIcon" && <Github width={18} height={18} />}
          {item.icon === "LinkedInIcon" && <Linkedin width={18} height={18} />}
        </a>
      ))
    }
  </div>
</header>
