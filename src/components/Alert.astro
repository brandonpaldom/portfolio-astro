---
import { Terminal, AlertCircle } from "@lucide/astro";

interface Props {
  title: string;
  description: string;
  variant?: "default" | "error";
}

const { title, description, variant = "default" } = Astro.props;
---

<div
  class:list={[
    "flex items-start gap-4 rounded-xl border p-4 shadow-lg ring-1",
    variant === "default" && "border-white/10 bg-white/5 ring-white/5",
    variant === "error" && "border-red-500/20 bg-red-500/5 ring-red-500/10 text-red-200",
  ]}
>
  <div class="mt-0.5 opacity-80">
    {variant === "default" ? <Terminal width={18} height={18} /> : <AlertCircle width={18} height={18} />}
  </div>
  <div class="flex flex-col gap-1">
    <p class="font-medium text-sm text-neutral-200">{title}</p>
    <p class="text-sm text-neutral-400 leading-relaxed">{description}</p>
  </div>
</div>

