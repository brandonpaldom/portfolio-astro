---
import { Image } from "astro:assets";
import RoleTimeline from "./RoleTimeline.astro";

interface Props {
  item: {
    image: string;
    title: string;
    organization: string;
    roles?: Role[];
    start: string;
    end?: string;
    summary?: string;
  };
}

interface Role {
  title: string;
  modality?: string;
}

const { item } = Astro.props;
---

<article class="flex flex-col gap-3 group">
  <div class="flex items-start gap-4">
    {
      item.image ? (
        <Image src={item.image} alt={item.organization} width={48} height={48} class="h-12 w-12 shrink-0 rounded-xl bg-white/5 ring-1 ring-white/10 p-1 object-contain transition-transform group-hover:scale-105" />
      ) : (
        <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-xl bg-neutral-900 ring-1 ring-white/10 text-neutral-400 font-display font-medium text-lg uppercase transition-transform group-hover:scale-105 group-hover:text-neutral-200">
          {item.organization.charAt(0)}
        </div>
      )
    }
    <div class="flex flex-col mt-0.5">
      <h3 class="font-medium text-neutral-200">
        {item.title}
      </h3>
      <div class="text-sm text-neutral-400 mt-0.5">
        <span class="text-neutral-300 font-medium">
          {item.organization}
        </span>
        <span class="mx-1.5 opacity-50">•</span>
        <span class="capitalize">
          {item.start} {item.end && `— ${item.end}`}
        </span>
      </div>
    </div>
  </div>
  {item.roles && <RoleTimeline roles={item.roles} />}
  {item.summary && <p class="text-sm leading-relaxed text-neutral-400 ml-16">{item.summary}</p>}
</article>
