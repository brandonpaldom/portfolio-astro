---
interface Props {
  skills: string[];
  reverse?: boolean;
}

import Chip from "./Chip.astro";

const { skills, reverse = false } = Astro.props;

// Duplicamos las skills múltiples veces para garantizar que el track sea mucho más ancho que cualquier contenedor
// y el scroll infinito no deje espacios en blanco en resoluciones altas.
const displaySkills = Array(8).fill(skills).flat();
---

<div
  class:list={[
    "carousel flex w-full overflow-hidden",
    { "carousel-reverse": reverse },
  ]}
>
  <div class="scroll carousel-track flex w-max shrink-0 flex-nowrap gap-2 pr-2 py-2">
    {displaySkills.map((skill) => <Chip label={skill} color="chip-secondary" />)}
  </div>
  <div class="scroll carousel-track flex w-max shrink-0 flex-nowrap gap-2 pr-2 py-2" aria-hidden="true">
    {displaySkills.map((skill) => <Chip label={skill} color="chip-secondary" />)}
  </div>
</div>

<style>
  .carousel-track {
    animation: scroll 120s linear infinite;
  }

  .carousel-reverse .carousel-track {
    animation-name: scroll-reverse;
  }

  @keyframes scroll {
    from {
      transform: translateX(0);
    }
    to {
      transform: translateX(-100%);
    }
  }

  @keyframes scroll-reverse {
    from {
      transform: translateX(-100%);
    }
    to {
      transform: translateX(0);
    }
  }

  .carousel:hover .carousel-track {
    animation-play-state: paused;
  }
</style>
