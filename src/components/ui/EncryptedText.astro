---
interface Props {
  text: string;
  className?: string;
  as?: "h1" | "h2" | "h3" | "h4" | "h5" | "h6" | "p" | "span" | "div";
}

const { text, className = "", as: Element = "span" } = Astro.props;

// Usamos un identificador único para poder tener múltiples textos encriptados en la misma página
const id = `encrypted-text-${Math.random().toString(36).substring(2, 9)}`;
---

<Element class:list={["encrypted-text", className]} data-text={text} id={id}>
  {text}
</Element>

<script>
  // Letras aleatorias para el efecto matrix/encrypted
  const letters = "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789@#$%&*";

  // Función para inicializar el efecto
  function initEncryptedText() {
    const elements = document.querySelectorAll(".encrypted-text");

    elements.forEach((el) => {
      // Evitamos ejecutar múltiples veces si ya se procesó
      if (el.hasAttribute("data-processed")) return;
      el.setAttribute("data-processed", "true");

      const targetText = el.getAttribute("data-text");
      if (!targetText) return;

      let iterations = 0;
      let interval: number;

      // Inicia el texto con un caracter encriptado o vacío
      el.textContent = targetText
        .split("")
        .map(() => letters[Math.floor(Math.random() * letters.length)])
        .join("");

      // Esperar un pequeño retraso antes de comenzar la animación
      setTimeout(() => {
        interval = window.setInterval(() => {
          el.textContent = targetText
            .split("")
            .map((letter, index) => {
              // Si la iteración ya superó esta letra, mostramos la letra final
              if (index < iterations) {
                return targetText[index];
              }
              // De lo contrario, seguimos mostrando letras aleatorias
              return letters[Math.floor(Math.random() * letters.length)];
            })
            .join("");

          // Controla la velocidad a la que se revelan las letras (1/3 incrementos = más letras mezcladas a la vez)
          if (iterations >= targetText.length) {
            clearInterval(interval);
          }

          iterations += 1 / 3;
        }, 30);
      }, 300); // 300ms delay antes de que empiece a desencriptar
    });
  }

  // Ejecutamos cuando el DOM esté listo
  document.addEventListener("DOMContentLoaded", initEncryptedText);
  // Y también escuchamos los eventos de Astro si se usan View Transitions
  document.addEventListener("astro:page-load", initEncryptedText);
</script>
