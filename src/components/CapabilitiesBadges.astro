---
import capabilities from "@data/capabilities.json";
---

<div class="flex flex-wrap gap-2">
  {capabilities.map((cap) => (
    <div class="group relative flex items-center gap-2 rounded-full bg-white/[0.02] px-4 py-2 ring-1 ring-white/10 hover:ring-white/20 transition-all duration-300 cursor-default">
      <span class="text-sm font-display font-semibold text-neutral-100">{cap.title}</span>
      <span class="text-xs text-neutral-500 font-mono">{cap.tools.length}</span>
      <div class="invisible group-hover:visible opacity-0 group-hover:opacity-100 transition-all duration-200 absolute left-0 top-full mt-2 z-10 flex flex-wrap gap-1.5 rounded-lg bg-neutral-900 p-3 ring-1 ring-white/10 shadow-xl min-w-max">
        {cap.tools.map((tool) => (
          <span class="rounded-full bg-white/5 px-2.5 py-1 text-xs text-neutral-300 ring-1 ring-white/10">{tool}</span>
        ))}
      </div>
    </div>
  ))}
</div>
