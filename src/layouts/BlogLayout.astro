---
import "@styles/global.css";
import "@fontsource/geist-sans/400.css";
import "@fontsource/geist-sans/500.css";
import "@fontsource/geist-sans/600.css";
import "@fontsource/geist-mono/400.css";
import "@fontsource/syne/500.css";
import "@fontsource/syne/600.css";

import { ViewTransitions } from "astro:transitions";
import SocialShare from "@components/SocialShare.astro";
import Navbar from "@components/Navbar.astro";
import Footer from "@components/Footer.astro";
import Spotlight from "@components/ui/Spotlight.astro";

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  author?: string;
  tags?: string[];
  heroImage?: string;
}

const { title, description, pubDate, author = "Brandon Palmeros", tags = [], heroImage } = Astro.props;

const formattedDate = new Intl.DateTimeFormat("es-ES", {
  year: "numeric",
  month: "long",
  day: "numeric",
}).format(pubDate);

const baseUrl = import.meta.env.PROD ? (Astro.site?.origin || Astro.url.origin) : Astro.url.origin;
const currentPath = Astro.url.pathname;
const currentUrl = new URL(currentPath, baseUrl).href;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="shortcut icon" href="/favicon.png" type="image/png" />
    <link rel="canonical" href={canonicalURL} />
    <title>{title} | Blog | Brandon Palmeros</title>
    <ViewTransitions />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="article" />
    <meta property="article:published_time" content={pubDate.toISOString()} />
    <meta property="article:author" content={author} />
    {heroImage && <meta property="og:image" content={heroImage} />}
    <script is:inline src="https://analytics.ahrefs.com/analytics.js" data-key="kJyOJz23V2iAZRK0zOQtTA" async></script>
  </head>
  <body class="bg-black text-neutral-400 font-sans antialiased selection:bg-neutral-800 selection:text-neutral-200">
    <div class="fixed inset-0 z-[-1] bg-black"></div>
    <div class="fixed inset-0 z-[-1] grid-bg pointer-events-none"></div>
    
    <div class="fixed inset-0 z-[-1] overflow-hidden pointer-events-none">
      <Spotlight className="-top-40 right-0 md:right-60 md:-top-20" fill="white" />
    </div>

    <div class="noise-bg fixed inset-0 z-[-1] opacity-[0.04] pointer-events-none mix-blend-overlay"></div>
    
    <div class="mx-auto flex max-w-2xl flex-col px-6 py-12 md:py-20 min-h-screen">
      <Navbar />
      <main class="flex grow flex-col gap-10 mt-16 mb-20">
        <article class="flex flex-col gap-10">
          <header class="flex flex-col gap-6">
            <h1 class="text-3xl font-display font-semibold tracking-tight text-neutral-100">{title}</h1>
            <div class="flex flex-wrap items-center gap-3 text-sm text-neutral-500">
              <time datetime={pubDate.toISOString()}>
                {formattedDate}
              </time>
              <span>•</span>
              <span>Por {author}</span>
            </div>
            {
              tags.length > 0 && (
                <div class="flex flex-wrap gap-2">
                  {tags.map((tag) => (
                    <span class="rounded-full bg-white/5 px-2.5 py-1 text-xs font-medium text-neutral-300 ring-1 ring-white/10 backdrop-blur-md">{tag}</span>
                  ))}
                </div>
              )
            }
          </header>
          {heroImage && <img src={heroImage} alt={title} class="w-full rounded-2xl ring-1 ring-white/10 object-cover object-top" />}
          
          <div class="prose prose-invert prose-neutral blog-content max-w-none prose-a:text-neutral-300 prose-a:decoration-neutral-600 hover:prose-a:decoration-white prose-img:rounded-xl prose-img:ring-1 prose-img:ring-white/10">
            <slot />
          </div>
          
          <div class="mt-8 border-t border-white/10 pt-8">
            <SocialShare title={title} description={description} url={currentUrl} />
          </div>
        </article>
      </main>
      <Footer />
    </div>

    <script>
      document.addEventListener("astro:page-load", () => {
        const codeBlocks = document.querySelectorAll("pre");

        codeBlocks.forEach((codeBlock) => {
          const wrapper = document.createElement("div");
          wrapper.className = "relative group";

          const copyButton = document.createElement("button");
          copyButton.className =
            "absolute top-3 right-3 p-2 rounded-lg bg-neutral-800/80 text-neutral-400 hover:text-white hover:bg-neutral-700/80 transition-all opacity-0 group-hover:opacity-100 ring-1 ring-white/10 backdrop-blur-sm cursor-pointer";
          copyButton.innerHTML = `<span class="sr-only">Copy code</span>`;
          copyButton.appendChild(document.createElementNS("http://www.w3.org/2000/svg", "svg"));

          const tooltip = document.createElement("span");
          tooltip.textContent = "Copiado";
          tooltip.className =
            'absolute -top-8 right-0 px-2 py-1 rounded bg-neutral-800 text-white text-xs font-medium opacity-0 transform translate-y-2 transition-all duration-300 ring-1 ring-white/20';
          copyButton.appendChild(tooltip);

          const svg = copyButton.querySelector("svg");
          svg.setAttribute("class", "w-4 h-4 fill-current");
          svg.setAttribute("stroke", "currentColor");
          svg.setAttribute("fill", "currentColor");
          svg.setAttribute("stroke-width", "0");
          svg.setAttribute("viewBox", "0 0 512 512");
          svg.setAttribute("xmlns", "http://www.w3.org/2000/svg");

          const path = document.createElementNS("http://www.w3.org/2000/svg", "path");
          path.setAttribute(
            "d",
            "M384 96L384 0h-112c-26.51 0-48 21.49-48 48v288c0 26.51 21.49 48 48 48H464c26.51 0 48-21.49 48-48V128h-95.1C398.4 128 384 113.6 384 96zM416 0v96h96L416 0zM192 352V128h-144c-26.51 0-48 21.49-48 48v288c0 26.51 21.49 48 48 48H240c26.51 0 48-21.49 48-48V384h-48C213.5 384 192 362.5 192 336V352z",
          );
          svg.appendChild(path);

          copyButton.addEventListener("click", () => {
            const code = codeBlock.querySelector("code")?.textContent || "";
            navigator.clipboard.writeText(code).then(() => {
              copyButton.classList.add("text-emerald-400");
              
              const tooltip = copyButton.querySelector("span:not(.sr-only)");
              tooltip.classList.remove("opacity-0", "translate-y-2");
              tooltip.classList.add("opacity-100", "translate-y-0");

              setTimeout(() => {
                copyButton.classList.remove("text-emerald-400");
                tooltip.classList.remove("opacity-100", "translate-y-0");
                tooltip.classList.add("opacity-0", "translate-y-2");
              }, 2000);
            });
          });

          codeBlock.parentNode.insertBefore(wrapper, codeBlock);
          wrapper.appendChild(codeBlock);
          wrapper.appendChild(copyButton);
        });
      });
    </script>
  </body>
</html>

